			"condition": "var_insulin_attempt_1 != 3 && var_insulin_attempt_2 != 3 && var_insulin_attempt_3 != 3 ",
			"variable": "var_db_dosage_remedial",
			"text": "Rhea required <b>3 units</b> of insulin."
		},
		{
			"id": "event_db_step06_dosage_13",
			"localization_guid": "bdd3dc6a",
			"type": "variabletext",
			"variable": "var_db_dosage_rationale",
			"text": "For a high-risk medication like insulin, check the policies where you work to determine if you need confirmation of the amount before administering it. This can prevent errors in dosage, like administering 3 mL instead of 3 units of insulin."
		}
	]
