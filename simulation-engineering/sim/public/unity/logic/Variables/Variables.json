	},
	{
		"id": "var_score_increment",
		"localization_guid": "7b146467",
		"name": "score_increment",
		"value": 0,
		"min": 0,
		"max": 100,
		"text": "Make sure Min can accommodate the lowest scoring weight and Max can accommodate the highest scoring weight.",
