	{
		"id": "var_TOTALSCORE_Raw",
		"localization_guid": "5ee4e4a7",
		"name": "TOTALSCORE_Raw",
		"value": 0,
		"min": 0,
		"max": 10000,
		"text": "Max Value does show up in reports, so set it to the highest possible raw score.",
