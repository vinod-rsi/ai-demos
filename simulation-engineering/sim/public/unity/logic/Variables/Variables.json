		"tracked": false,
		"import_starting_value": false,
		"export_ending_value": false
	},
	{
		"id": "var_TOTALSCORE_PctCorrect",
		"localization_guid": "a09c93f0",
		"name": "TOTALSCORE_PctCorrect",
		"value": 0,
		"min": 0,
		"max": 100,
		"text": "",
		"reset_text": false,
		"tracked": true,
		"import_starting_value": false,
		"export_ending_value": false
	},
	{
		"id": "var_TOTALSCORE_MinRaw",
		"localization_guid": "650f7d51",
		"name": "TOTALSCORE_MinRaw",
		"value": 0,
		"min": 0,
		"max": 100,
		"text": "Necessary for calculating percent-correct scores.\n\nSet its Value according to what will be in the menu on the first turn. If a Poor will be available, set it to your Poor score weight; if only a Weak will be available, set it to your Weak weight, etc.\n\nMake sure the Min and Max properties can accommodate the bottom end of possible raw scores in your convo. It doesn't hurt to set them arbitrarily low/high, like -1000 and 1000.",
		"reset_text": false,
		"tracked": true,
		"import_starting_value": false,
		"export_ending_value": false
	},
	{
		"id": "var_TOTALSCORE_MaxRaw",
		"localization_guid": "be1e192d",
		"name": "TOTALSCORE_MaxRaw",
		"value": 10,
		"min": 0,
		"max": 100,
		"text": "Necessary for calculating percent-correct scores.\n\nSet its Value according to what will be in the menu on the first turn. If a Target will be available, set it to your Target score weight; if only a Fair will be available, set it to your Fair weight, etc.\n\nMake sure the Min and Max properties can accommodate the top end of possible raw scores in your convo. It doesn't hurt to set them arbitrarily low/high, like -1000 and 1000.",
		"reset_text": false,
		"tracked": true,
		"import_starting_value": false,
		"export_ending_value": false
	},
	{
		"id": "var_TOTALSCORE_PerfLvl",
		"localization_guid": "7705fb7c",
		"name": "TOTALSCORE_PerfLvl",
		"value": 0,
		"min": 0,
		"max": 2,
		"text": "Assuming three performance levels. Adjust as necessary.",
		"reset_text": false,
		"tracked": true,
		"import_starting_value": false,
		"export_ending_value": false
	},
	{
		"id": "var_WEIGHT_Target",
		"localization_guid": "67df6528",
		"name": "WEIGHT_Target",
		"value": 10,
		"min": 0,
		"max": 100,
		"text": "This sets the scoring weight of Target nodes. Assumes a weight of 10; adjust the Value field above as necessary.",
		"reset_text": false,
		"tracked": false,
		"import_starting_value": false,
		"export_ending_value": false
	},
	{
		"id": "var_WEIGHT_Fair",
